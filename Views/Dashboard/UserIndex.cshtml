@model IEnumerable<GreenRoots.DTOs.TreeRequestResponseDto>
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="container mt-5">
    <h2 class="mb-1 text-success fw-bold">Welcome, @ViewBag.UserName! ðŸ‘‹</h2>
    <p class="text-muted mb-4">Here is your tree plantation impact summary.</p>

    <!-- Stats Row -->
    <div class="row mb-4 g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card p-4">
                <h6 class="text-muted text-uppercase">Total Requested</h6>
                <h2 class="fw-bold text-success">@ViewBag.Total</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4" style="border-left: 5px solid #f39c12 !important;">
                <h6 class="text-muted text-uppercase">Pending</h6>
                <h2 class="fw-bold" style="color:#f39c12">@ViewBag.Pending</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card p-4">
                <h6 class="text-muted text-uppercase">Planted</h6>
                <h2 class="fw-bold text-success">@ViewBag.Planted</h2>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="mb-4 d-flex gap-3">
        <a asp-controller="Requests" asp-action="Submit" class="btn btn-success fw-bold">ðŸŒ± Plant a Tree</a>
        <a asp-controller="Requests" asp-action="MyRequests" class="btn btn-outline-success fw-bold">ðŸ“‹ My Requests</a>
    </div>

    <!-- Recent Requests -->
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h5 class="fw-bold text-success mb-3">Recent Requests</h5>
            @if (!Model.Any())
            {
                <div class="text-center text-muted py-4">
                    <p>You haven't made any requests yet.</p>
                    <a asp-controller="Requests" asp-action="Submit" class="btn btn-success">Submit Your First Request</a>
                </div>
            }
            else
            {
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Location</th>
                            <th>Trees</th>
                            <th>Status</th>
                            <th>Payment</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in Model.Take(5))
                        {
                            <tr>
                                <td>@req.Location</td>
                                <td>@req.NumberOfTrees</td>
                                <td><span class="badge @(req.Status == "Planted" ? "badge-planted" : "badge-pending")">@req.Status</span></td>
                                <td><span class="badge @(req.PaymentStatus == "Paid" ? "badge-paid" : "badge-pending")">@req.PaymentStatus</span></td>
                                <td>@req.CreatedAt.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
