@model IEnumerable<GreenRoots.API.DTOs.TreeRequestResponseDto>
@{
    ViewData["Title"] = "My Requests";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-success mb-1">My Tree Requests 🌳</h2>
            <p class="text-muted">Track all your plantation requests and their statuses.</p>
        </div>
        <a asp-controller="Requests" asp-action="Submit" class="btn btn-success fw-bold">+ New Request</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <div class="display-3">🌱</div>
                    <p class="mt-3">You haven't planted any trees yet!</p>
                    <a asp-controller="Requests" asp-action="Submit" class="btn btn-success fw-bold">Submit Your First Request</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Location</th>
                                <th>Message</th>
                                <th>Trees</th>
                                <th>Status</th>
                                <th>Payment</th>
                                <th>Requested On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in Model)
                            {
                                <tr>
                                    <td>@req.Id</td>
                                    <td>@req.Location</td>
                                    <td class="text-muted">@(string.IsNullOrEmpty(req.Message) ? "-" : req.Message)</td>
                                    <td>@req.NumberOfTrees</td>
                                    <td><span class="badge @(req.Status == "Planted" ? "badge-planted" : "badge-pending")">@req.Status</span></td>
                                    <td><span class="badge @(req.PaymentStatus == "Paid" ? "badge-paid" : "badge-pending")">@req.PaymentStatus</span></td>
                                    <td>@req.CreatedAt.ToString("dd MMM yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
