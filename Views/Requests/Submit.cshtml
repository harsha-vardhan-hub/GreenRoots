@model GreenRoots.API.DTOs.CreateTreeRequestDto
@{
    ViewData["Title"] = "Plant a Tree";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <h2 class="text-success fw-bold mb-1">🌱 Plant a Tree</h2>
                    <p class="text-muted mb-4">Fill in the details below and complete the simulated payment to submit your request.</p>

                    <form id="submitForm" asp-action="Submit" method="post">
                        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Location" class="form-label fw-semibold">📍 Location</label>
                            <input asp-for="Location" class="form-control" placeholder="e.g. Central Park, New York" />
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NumberOfTrees" class="form-label fw-semibold">🌳 Number of Trees</label>
                            <input asp-for="NumberOfTrees" type="number" min="1" class="form-control" placeholder="e.g. 5" />
                            <span asp-validation-for="NumberOfTrees" class="text-danger small"></span>
                            <div class="form-text text-muted">Estimated cost: <strong id="costEstimate">₹0</strong> (₹500 per tree)</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Message" class="form-label fw-semibold">💬 Message (Optional)</label>
                            <textarea asp-for="Message" class="form-control" rows="3" placeholder="e.g. Planting in memory of my grandfather..."></textarea>
                        </div>

                        <!-- Trigger payment modal, not direct submit -->
                        <button type="button" id="proceedBtn" class="btn btn-success w-100 fw-bold">
                            Proceed to Payment →
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold">💳 Simulated Payment</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div id="paymentForm">
                    <p class="text-muted mb-3">Enter your card details to complete the payment. <span class="badge bg-warning text-dark">Demo Only</span></p>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Card Number</label>
                        <input type="text" class="form-control" value="4242 4242 4242 4242" readonly />
                    </div>
                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label fw-semibold">Expiry</label>
                            <input type="text" class="form-control" value="12/28" readonly />
                        </div>
                        <div class="col">
                            <label class="form-label fw-semibold">CVV</label>
                            <input type="text" class="form-control" value="***" readonly />
                        </div>
                    </div>
                    <div class="alert alert-success mb-0">
                        Total: <strong id="modalCost">₹0</strong>
                    </div>
                </div>

                <!-- Processing spinner -->
                <div id="processingDiv" class="text-center py-3 d-none">
                    <div class="spinner-border text-success mb-3" role="status"></div>
                    <p class="fw-semibold text-muted">Processing payment...</p>
                </div>

                <!-- Success state -->
                <div id="successDiv" class="text-center py-3 d-none">
                    <div class="display-3">✅</div>
                    <h5 class="mt-3 text-success fw-bold">Payment Successful!</h5>
                    <p class="text-muted">Submitting your tree planting request...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="payNowBtn" class="btn btn-success fw-bold">Pay Now</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const treesInput = document.getElementById('NumberOfTrees');
    const costEstimate = document.getElementById('costEstimate');
    const modalCost = document.getElementById('modalCost');

    function updateCost() {
        const trees = parseInt(treesInput.value) || 0;
        const cost = `₹${trees * 500}`;
        costEstimate.textContent = cost;
        modalCost.textContent = cost;
    }

    treesInput.addEventListener('input', updateCost);
    updateCost();

    document.getElementById('proceedBtn').addEventListener('click', () => {
        const location = document.getElementById('Location').value.trim();
        const trees = parseInt(treesInput.value);

        if (!location) {
            alert('Please enter a location before proceeding.');
            return;
        }
        if (!trees || trees < 1) {
            alert('Please enter a valid number of trees (at least 1).');
            return;
        }

        updateCost();
        new bootstrap.Modal(document.getElementById('paymentModal')).show();
    });

    document.getElementById('payNowBtn').addEventListener('click', () => {
        document.getElementById('paymentForm').classList.add('d-none');
        document.getElementById('processingDiv').classList.remove('d-none');
        document.querySelector('.modal-footer').innerHTML = '';

        setTimeout(() => {
            document.getElementById('processingDiv').classList.add('d-none');
            document.getElementById('successDiv').classList.remove('d-none');

            // Submit the actual form after showing success
            setTimeout(() => {
                document.getElementById('submitForm').submit();
            }, 1500);
        }, 2000);
    });
</script>
}
